VITE_API_URL = https://backend-1-ghrv.onrender.com/api
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GITHUB_CLIENT_ID=your_github_client_id_here
VITE_GITHUB_REDIRECT_PATH=/
VITE_GITHUB_SCOPE=read:user user:email

# Primary AI provider (recommended)
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here
VITE_DEEPSEEK_MODEL=deepseek-chat

# Fallback AI provider
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_MODEL=gemini-2.0-flash

# Last-resort browser fallback (Puter.js)
VITE_PUTER_MODEL=gpt-5-nano
