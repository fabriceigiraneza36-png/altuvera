// src/context/UserAuthContext.jsx
import React, {
  createContext,
  useContext,
  useState,
  useEffect,
  useCallback,
  useRef,
} from "react";

const API = import.meta.env.VITE_API_URL || "http://localhost:3000";

const UserAuthContext = createContext(null);

/* ── Token helpers ── */
const getToken = () =>
  localStorage.getItem("authToken") || sessionStorage.getItem("authToken");

const setToken = (token, persist = true) => {
  if (persist) {
    localStorage.setItem("authToken", token);
    sessionStorage.removeItem("authToken");
  } else {
    sessionStorage.setItem("authToken", token);
    localStorage.removeItem("authToken");
  }
};

const clearToken = () => {
  localStorage.removeItem("authToken");
  sessionStorage.removeItem("authToken");
  localStorage.removeItem("userData");
};

const saveUser = (user) =>
  localStorage.setItem("userData", JSON.stringify(user));

const loadUser = () => {
  try {
    return JSON.parse(localStorage.getItem("userData") || "null");
  } catch {
    return null;
  }
};

/* ── API helper ── */
const apiFetch = async (path, opts = {}) => {
  const token = getToken();
  const res = await fetch(`${API}${path}`, {
    ...opts,
    headers: {
      "Content-Type": "application/json",
      ...(token ? { Authorization: `Bearer ${token}` } : {}),
      ...(opts.headers || {}),
    },
  });
  const data = await res.json().catch(() => ({}));
  if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
  return data;
};

/* ── Google helpers ── */
const GOOGLE_CLIENT_ID = import.meta.env.VITE_GOOGLE_CLIENT_ID || "";

export function UserAuthProvider({ children }) {
  /* Modal state */
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [modalView, setModalView] = useState("login"); // "login" | "register" | "verify"

  /* Auth state */
  const [user, setUser] = useState(() => loadUser());
  const [isAuthenticated, setIsAuthenticated] = useState(() => !!getToken() && !!loadUser());
  const [isLoading, setIsLoading] = useState(false);

  /* Pending email for OTP verify */
  const [pendingEmail, setPendingEmail] = useState("");
  const [persistSession, setPersistSession] = useState(true);

  /* Google */
  const [googleUser, setGoogleUser] = useState(null);
  const [googleLoaded, setGoogleLoaded] = useState(false);
  const [googleLoading, setGoogleLoading] = useState(false);
  const [hasGooglePending, setHasGooglePending] = useState(false);

  /* GitHub */
  const [githubLoading, setGithubLoading] = useState(false);

  /* Social error */
  const [socialAuthError, setSocialAuthError] = useState("");

  /* Avatar upload ref */
  const pendingAvatarFile = useRef(null);

  /* ── Load Google Identity Services ── */
  useEffect(() => {
    if (!GOOGLE_CLIENT_ID) { setGoogleLoaded(false); return; }
    if (window.google?.accounts) { setGoogleLoaded(true); return; }
    const script = document.createElement("script");
    script.src = "https://accounts.google.com/gsi/client";
    script.async = true;
    script.defer = true;
    script.onload = () => setGoogleLoaded(true);
    script.onerror = () => setGoogleLoaded(false);
    document.head.appendChild(script);
    return () => {
      if (document.head.contains(script)) document.head.removeChild(script);
    };
  }, []);

  /* ── Verify token on mount ── */
  useEffect(() => {
    const token = getToken();
    if (!token) return;
    apiFetch("/api/users/profile")
      .then((data) => {
        const u = data.data || data.user || data;
        setUser(u);
        saveUser(u);
        setIsAuthenticated(true);
      })
      .catch(() => {
        clearToken();
        setUser(null);
        setIsAuthenticated(false);
      });
  }, []);

  /* ── GitHub OAuth callback ── */
  useEffect(() => {
    const params = new URLSearchParams(window.location.search);
    const ghToken = params.get("github_token") || params.get("token");
    const ghUser = params.get("user");
    if (!ghToken) return;
    try {
      const parsed = ghUser ? JSON.parse(decodeURIComponent(ghUser)) : null;
      setToken(ghToken, persistSession);
      if (parsed) { setUser(parsed); saveUser(parsed); }
      setIsAuthenticated(true);
      setGithubLoading(false);
      // Clean URL
      const clean = window.location.pathname;
      window.history.replaceState({}, "", clean);
      setIsModalOpen(false);
    } catch (err) {
      setSocialAuthError("GitHub authentication failed.");
    }
  }, [persistSession]);

  /* ── Helpers ── */
  const openModal = useCallback((view = "login") => {
    setModalView(view);
    setIsModalOpen(true);
  }, []);

  const closeModal = useCallback(() => {
    setIsModalOpen(false);
    setPendingEmail("");
    setSocialAuthError("");
  }, []);

  const setSessionPreference = useCallback((persist) => {
    setPersistSession(persist);
  }, []);

  const clearSocialAuthError = useCallback(() => {
    setSocialAuthError("");
  }, []);

  const clearGooglePending = useCallback(() => {
    setGoogleUser(null);
    setHasGooglePending(false);
  }, []);

  /* ── Login (sends OTP) ── */
  const login = useCallback(async ({ email, fullName, persistSession: ps }) => {
    const data = await apiFetch("/api/users/login", {
      method: "POST",
      body: JSON.stringify({ email: email.trim(), fullName: fullName.trim() }),
    });
    setPendingEmail(email.trim());
    if (ps !== undefined) setPersistSession(ps);
    setModalView("verify");
    return data;
  }, []);

  /* ── Register (sends OTP) ── */
  const register = useCallback(
    async ({ email, fullName, phone, bio, careers, role, avatar, persistSession: ps }) => {
      const data = await apiFetch("/api/users/register", {
        method: "POST",
        body: JSON.stringify({
          email: email.trim(),
          fullName: fullName.trim(),
          phone: phone || "",
          bio: bio || "",
          careers: careers || [],
          role: role || "traveler",
          avatar: avatar || "",
        }),
      });
      setPendingEmail(email.trim());
      if (ps !== undefined) setPersistSession(ps);
      setModalView("verify");
      return data;
    },
    []
  );

  /* ── Verify OTP ── */
  const verifyCode = useCallback(
    async (email, code) => {
      const data = await apiFetch("/api/users/verify", {
        method: "POST",
        body: JSON.stringify({ email: email.trim(), code: code.trim() }),
      });
      const token = data.token || data.data?.token;
      const userData = data.user || data.data?.user || data.data;
      if (!token) throw new Error("No token received from server.");
      setToken(token, persistSession);
      if (userData) { setUser(userData); saveUser(userData); }
      setIsAuthenticated(true);
      setPendingEmail("");
      setIsModalOpen(false);
      setModalView("login");
      return data;
    },
    [persistSession]
  );

  /* ── Resend OTP ── */
  const resendCode = useCallback(async (email) => {
    const data = await apiFetch("/api/users/resend-code", {
      method: "POST",
      body: JSON.stringify({ email: email.trim() }),
    });
    return data;
  }, []);

  /* ── Google Auth ── */
  const promptGoogleAuth = useCallback(
    async ({ mode = "signin" } = {}) => {
      if (!googleLoaded || !window.google?.accounts) {
        throw new Error("Google Sign-In is not available.");
      }
      setGoogleLoading(true);
      return new Promise((resolve, reject) => {
        try {
          window.google.accounts.id.initialize({
            client_id: GOOGLE_CLIENT_ID,
            callback: async (response) => {
              try {
                const endpoint =
                  mode === "signup"
                    ? "/api/users/google/signup-init"
                    : "/api/users/google/signin";
                const data = await apiFetch(endpoint, {
                  method: "POST",
                  body: JSON.stringify({ credential: response.credential }),
                });
                if (mode === "signin") {
                  const token = data.token || data.data?.token;
                  const userData = data.user || data.data?.user || data.data;
                  if (token) {
                    setToken(token, persistSession);
                    if (userData) { setUser(userData); saveUser(userData); }
                    setIsAuthenticated(true);
                    setIsModalOpen(false);
                  }
                  resolve(data);
                } else {
                  // signup init — store google profile for step 2
                  const profile = data.profile || data.data?.profile || {};
                  setGoogleUser({
                    email: profile.email || data.email || "",
                    name: profile.name || data.name || "",
                    picture: profile.picture || data.picture || "",
                    googleId: profile.googleId || data.googleId || "",
                    credential: response.credential,
                  });
                  setHasGooglePending(true);
                  resolve(profile);
                }
              } catch (err) {
                setSocialAuthError(err.message);
                reject(err);
              } finally {
                setGoogleLoading(false);
              }
            },
          });
          window.google.accounts.id.prompt((notification) => {
            if (
              notification.isSkippedMoment() ||
              notification.isDismissedMoment()
            ) {
              setGoogleLoading(false);
              resolve({ dismissed: true });
            }
          });
        } catch (err) {
          setGoogleLoading(false);
          reject(err);
        }
      });
    },
    [googleLoaded, persistSession]
  );

  /* ── Complete Google Sign Up ── */
  const completeGoogleSignUp = useCallback(
    async ({ fullName, phone, bio, careers, role, avatar }) => {
      if (!googleUser?.credential) throw new Error("No Google credential found.");
      const data = await apiFetch("/api/users/google/signup-complete", {
        method: "POST",
        body: JSON.stringify({
          credential: googleUser.credential,
          fullName: fullName || googleUser.name,
          phone: phone || "",
          bio: bio || "",
          careers: careers || [],
          role: role || "traveler",
          avatar: avatar || googleUser.picture || "",
        }),
      });
      const token = data.token || data.data?.token;
      const userData = data.user || data.data?.user || data.data;
      if (token) {
        setToken(token, persistSession);
        if (userData) { setUser(userData); saveUser(userData); }
        setIsAuthenticated(true);
        setGoogleUser(null);
        setHasGooglePending(false);
        setIsModalOpen(false);
      }
      return data;
    },
    [googleUser, persistSession]
  );

  /* ── GitHub Auth ── */
  const startGithubAuth = useCallback(
    (mode = "signin") => {
      setGithubLoading(true);
      const redirect = `${API}/api/users/github/${mode === "signup" ? "signup" : "signin"}`;
      window.location.href = redirect;
    },
    []
  );

  /* ── Upload Avatar ── */
  const uploadAvatar = useCallback(async (file) => {
    const formData = new FormData();
    formData.append("avatar", file);
    const token = getToken();
    const res = await fetch(`${API}/api/uploads/avatar`, {
      method: "POST",
      headers: token ? { Authorization: `Bearer ${token}` } : {},
      body: formData,
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(data.message || "Upload failed");
    return data.url || data.data?.url || data.avatarUrl || "";
  }, []);

  /* ── Logout ── */
  const logout = useCallback(() => {
    clearToken();
    setUser(null);
    setIsAuthenticated(false);
    setPendingEmail("");
    setGoogleUser(null);
    setHasGooglePending(false);
    try { window.google?.accounts?.id?.disableAutoSelect?.(); } catch {}
  }, []);

  /* ── Update profile ── */
  const updateProfile = useCallback(async (updates) => {
    const data = await apiFetch("/api/users/profile", {
      method: "PUT",
      body: JSON.stringify(updates),
    });
    const updated = data.data || data.user || data;
    setUser(updated);
    saveUser(updated);
    return updated;
  }, []);

  const value = {
    /* Modal */
    isModalOpen,
    modalView,
    setModalView,
    openModal,
    closeModal,
    /* Auth */
    user,
    isAuthenticated,
    isLoading,
    persistSession,
    setSessionPreference,
    /* Actions */
    login,
    register,
    verifyCode,
    resendCode,
    logout,
    updateProfile,
    uploadAvatar,
    /* Pending */
    pendingEmail,
    /* Google */
    googleUser,
    googleLoaded,
    googleLoading,
    hasGooglePending,
    promptGoogleAuth,
    completeGoogleSignUp,
    clearGooglePending,
    /* GitHub */
    githubLoading,
    startGithubAuth,
    /* Social error */
    socialAuthError,
    clearSocialAuthError,
  };

  return (
    <UserAuthContext.Provider value={value}>
      {children}
    </UserAuthContext.Provider>
  );
}

export function useUserAuth() {
  const ctx = useContext(UserAuthContext);
  if (!ctx) throw new Error("useUserAuth must be used within UserAuthProvider");
  return ctx;
}
